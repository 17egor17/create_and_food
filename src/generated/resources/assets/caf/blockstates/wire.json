{
  "multipart": [
    {
      "apply": {
        "model": "caf:block/wire/wire_single"
      }
    },
    {
      "when": {
        "north": "true"
      },
      "apply": {
        "model": "caf:block/wire/wire_connect"
      }
    },
    {
      "when": {
        "east": "true"
      },
      "apply": {
        "model": "caf:block/wire/wire_connect",
        "y": 90
      }
    },
    {
      "when": {
        "south": "true"
      },
      "apply": {
        "model": "caf:block/wire/wire_connect",
        "y": 180
      }
    },
    {
      "when": {
        "west": "true"
      },
      "apply": {
        "model": "caf:block/wire/wire_connect",
        "y": 270
      }
    },
    {
      "when": {
        "up": "true"
      },
      "apply": {
        "model": "caf:block/wire/wire_connect",
        "x": 270
      }
    },
    {
      "when": {
        "down": "true"
      },
      "apply": {
        "model": "caf:block/wire/wire_connect",
        "x": 90
      }
    }
  ]
}